# Set one LLM key. If AGT_LLM_PROVIDER is unset, runtime auto-detects OpenAI,
# then Anthropic, then xAI, then Groq.
AGT_OPENAI_API_KEY=
AGT_ANTHROPIC_API_KEY=
AGT_XAI_API_KEY=
AGT_GROQ_API_KEY=
AGT_ZOTERO_API_KEY=
AGT_ZOTERO_LIBRARY_ID=
AGT_ZOTERO_LIBRARY_TYPE=user
AGT_ZOTERO_COLLECTION_NAME=SciAgent
AGT_SEMANTIC_SCHOLAR_API_KEY=
# Optional explicit provider/model override:
# AGT_LLM_PROVIDER=openai
# AGT_MODEL_NAME=gpt-5.4
AGT_TIMEOUT_SECONDS=30
AGT_RETRIES=3
AGT_LOG_LEVEL=INFO

# Generic OpenAI-compatible endpoint — DeepSeek, Together AI, LM Studio, etc. (SCI-0601)
# AGT_LLM_PROVIDER=openai-compatible
# AGT_LLM_BASE_URL=https://api.deepseek.com/v1
# AGT_LLM_API_KEY=your-key-here
# AGT_LLM_MODEL=deepseek-chat

# Ollama — fully offline, no API key needed (SCI-0602)
# AGT_LLM_PROVIDER=ollama
# AGT_LLM_MODEL=llama3.2

# Embedded server data directory (SCI-0604)
# AGT_DATA_DIR=~/.sciagent

# Backend security (SCI-0501)
# AGT_BACKEND_API_KEY=change-me-to-a-random-secret
# AGT_CORS_ALLOWED_ORIGINS=["*"]
# AGT_API_RATE_LIMIT=200/minute
