# Set one LLM key. If AGT_LLM_PROVIDER is unset, runtime auto-detects OpenAI,
# then Anthropic, then xAI, then Groq.
AGT_OPENAI_API_KEY=
AGT_ANTHROPIC_API_KEY=
AGT_XAI_API_KEY=
AGT_ZOTERO_API_KEY=
AGT_ZOTERO_LIBRARY_ID=
AGT_ZOTERO_LIBRARY_TYPE=user
AGT_ZOTERO_COLLECTION_NAME=SciAgent
AGT_SEMANTIC_SCHOLAR_API_KEY=
# Optional explicit provider/model override:
# AGT_LLM_PROVIDER=openai
# AGT_MODEL_NAME=gpt-5.4
AGT_TIMEOUT_SECONDS=30
AGT_RETRIES=3
AGT_LOG_LEVEL=INFO
